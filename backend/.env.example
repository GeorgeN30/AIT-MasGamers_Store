# Puerto del servidor (default: 3000)
PORT=3000

# Secreto para firmar JWT - OBLIGATORIO, cambiar en producción
JWT_SECRET=mysecretkey

# Tiempo de expiración del token (default: 7d)
JWT_EXPIRES_IN=7d

# Credenciales del admin para el seed (defaults en seed.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_SECURITY_WORD=masgamers

# Core Infra API (notify-mail-service + crypto-vault + live-event-gateway)
NOTIFY_API_URL=https://core.cable-visiont.com
NOTIFY_API_KEY=
